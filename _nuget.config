<?xml version="1.0" encoding="utf-8"?>
<!--
  CI-only NuGet config. The active nuget.config points at nuget.org for local/standalone dev
  (the in-cluster Nexus proxy below is unreachable outside the cluster). CI on the self-hosted
  runner copies this over the active config before restore:  cp _nuget.config nuget.config
  Mirrors the DonkeyWork-Agents convention.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nexus" value="http://nexus.nexus.svc.cluster.local:8081/repository/nuget.org-proxy/index.json" allowInsecureConnections="true" />
  </packageSources>
</configuration>
